# Copy to .env (already gitignored) and fill in for local script testing.
# Never commit real values. See scripts/oauth_bootstrap.py for how to get
# the Google values; developer.spotify.com for the Spotify ones.
#
# These five are consumed by scripts/ (the presentation.yml stage: attendance_
# check.py, spotify_lookup.py, calendar_create.py). They need to be set again,
# separately, as GitHub Actions repo secrets (Settings > Secrets and
# variables > Actions) for presentation.yml to run for real -- this .env is
# for local testing only.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional; defaults to data/event-picks-log.csv (repo-relative) if unset.
# PICKS_LOG_PATH=
